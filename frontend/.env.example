# ── LOCAL DEVELOPMENT ──────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git!

# Your Anthropic API key — required for local dev (direct browser calls)
# Get one at https://console.anthropic.com
VITE_ANTHROPIC_API_KEY=sk-ant-api03-...

# ── PRODUCTION (set these after running: cdk deploy) ──────────────────────────
# API Gateway URL (from CDK output)
VITE_API_URL=https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com/prod

# AWS Region
VITE_AWS_REGION=us-east-1

# Cognito (for auth)
VITE_COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# S3 Bucket name (from CDK output)
VITE_S3_BUCKET=notegenius-uploads-xxxxxxxxxxxx
